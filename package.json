{
  "name": "buildbeat",
  "version": "0.1.1",
  "description": "Your codebase gets a live, adaptive soundtrack: tension when tests fail, a resolve on git commit.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "buildbeat": "dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "bun build src/cli.ts --target node --outfile dist/cli.js",
    "prepublishOnly": "bun run build",
    "start": "bun run src/cli.ts start",
    "demo": "bun run src/cli.ts demo",
    "watch": "bun run src/cli.ts watch --test \"bun test\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/bun": "latest",
    "@types/ws": "^8.5.10",
    "chokidar": "^5.0.0",
    "typescript": "^5.6.0",
    "ws": "^8.18.0"
  }
}
